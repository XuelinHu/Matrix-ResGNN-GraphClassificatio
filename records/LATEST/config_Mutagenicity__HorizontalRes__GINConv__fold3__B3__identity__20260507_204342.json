{
  "dataset": "Mutagenicity",
  "model": "HorizontalRes",
  "operator": "GINConv",
  "version": "LATEST",
  "fold": 3,
  "seed": 1024,
  "ep": 200,
  "lr": 0.005,
  "weight_decay": 0.0001,
  "drop": 0.5,
  "dim": 64,
  "h_layer": 4,
  "num_branches": 3,
  "batch_size": 256,
  "val_ratio": 0.1,
  "patience": 60,
  "min_delta": 0.0,
  "grad_clip": 2.0,
  "lr_factor": 0.5,
  "lr_patience": 15,
  "min_lr": 1e-05,
  "gate_init": 0.8,
  "gate_mode": "learnable",
  "fixed_gate_value": 0.8,
  "residual_mode": "identity",
  "topk_ratio": 0.5,
  "sparse_lambda": 0.05
}